class Solution:
    def isIsomorphic(self, s, t):

        # If lengths are different
        if len(s) != len(t):
            return False

        # Dictionaries for mapping
        map_st = {}
        map_ts = {}

        # Traverse both strings
        for i in range(len(s)):

            ch1 = s[i]
            ch2 = t[i]

            # Check s -> t mapping
            if ch1 in map_st:
                if map_st[ch1] != ch2:
                    return False
            else:
                map_st[ch1] = ch2

            # Check t -> s mapping
            if ch2 in map_ts:
                if map_ts[ch2] != ch1:
                    return False
            else:
                map_ts[ch2] = ch1

        return True
