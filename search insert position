class Solution:
    def searchInsert(self, nums, target):
        
        left = 0
        right = len(nums) - 1
        
        while left <= right:
            
            mid = (left + right) // 2
            
            # If target found
            if nums[mid] == target:
                return mid
            
            # Search in right half
            elif nums[mid] < target:
                left = mid + 1
            
            # Search in left half
            else:
                right = mid - 1
        
        # Position where target should be inserted
        return left


# Example Usage
sol = Solution()

print(sol.searchInsert([1,3,5,6], 5))   # Output: 2
print(sol.searchInsert([1,3,5,6], 2))   # Output: 1
print(sol.searchInsert([1,3,5,6], 7))   # Output: 4
